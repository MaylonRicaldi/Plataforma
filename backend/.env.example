# =========================
# BACKEND — PreguntaIA
# =========================
# Copia este archivo a .env y completa los valores reales.
# NUNCA subas .env al repositorio.

# --- Google Gemini API (Motor IA primario) ---
# Si no se provee, el motor Bloom local (spaCy) funciona como fallback.
GEMINI_API_KEY=tu-api-key-de-gemini

# --- Puerto del servidor Flask ---
PORT=5000

# --- Modo debug (1=activado) ---
FLASK_DEBUG=1

# --- Entorno (development / production) ---
# production deshabilita Swagger UI automaticamente
FLASK_ENV=development

# --- Origenes CORS permitidos (separados por coma) ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Directorio de logs ---
LOG_DIR=logs

# --- Host para documentacion Swagger ---
SWAGGER_HOST=localhost:5000

# --- Credenciales Firebase (3 formas, una debe estar activa) ---
# Opcion 1: JSON completo como variable de entorno (recomendado para Render/Vercel)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":...}

# Opcion 2: Ruta al archivo de service account de Firebase
# GOOGLE_APPLICATION_CREDENTIALS=serviceAccountKey.json
